---
import Base from '../layouts/Base.astro';
---

<Base title="Ask AI — Rishikesh Sangareddypeta">
  <main class="chatmain">
    <div class="chatcol">

      <section class="intro reveal">
        <span class="mono eyebrow">Ask AI — about Rishikesh’s work<span class="status"><span class="dot"></span>Online</span></span>
        <h1>Ask me anything about Rishikesh — his roles, research, and the <em>way he builds</em>.<span class="caret"></span></h1>
      </section>

      <section class="thread">
        <article class="exchange reveal">
          <div class="q">
            <span class="mono qlabel">Q.</span>
            <p class="qtext">What did he actually ship at Copart?</p>
          </div>
          <div class="a">
            <span class="mono alabel">A.</span>
            <div class="atext">
              <p>At Copart he moved through three roles — <strong>QA, then Salesforce, then Software Developer</strong> — and worked on the <strong>Java / Spring Boot</strong> microservices behind enterprise auction and seller-billing workflows.</p>
              <p>His most measurable contribution was test infrastructure: roughly <span class="hl">200–250 automated UI and API tests</span> plus a regression suite that <span class="hl">cut manual QA effort by about 40%</span>, which tightened release cycles.</p>
              <a class="cite" href="/#work">Source — Selected Work</a>
            </div>
          </div>
        </article>

        <article class="exchange reveal">
          <div class="q">
            <span class="mono qlabel">Q.</span>
            <p class="qtext">How research-heavy is he, really?</p>
          </div>
          <div class="a">
            <span class="mono alabel">A.</span>
            <div class="atext">
              <p>Genuinely hands-on. At <strong>Georgia State</strong> he’s building a <strong>multimodal IMU + camera pipeline</strong> that scores hand-movement smoothness, fusing inertial signals with MediaPipe pose data and computing a <span class="hl">Normalized Jerk Score</span>.</p>
              <p>Earlier, at <strong>KMIT’s R&amp;D lab</strong>, he built histopathology AI on <span class="hl">~8&nbsp;GB whole-slide images</span> using YOLOv5/8 and U-Net — a related stroke-classification model reached ~91% accuracy.</p>
              <a class="cite" href="/#work">Source — Research</a>
            </div>
          </div>
        </article>
      </section>

      <section class="suggest reveal">
        <span class="mono sl">Try asking</span>
        <div class="chips">
          <button class="chip" type="button"><span class="ct">Is he stronger at backend or ML?</span><span class="cgo">Ask →</span></button>
          <button class="chip" type="button"><span class="ct">What kind of internship is he looking for?</span><span class="cgo">Ask →</span></button>
          <button class="chip" type="button"><span class="ct">Walk me through the whole-slide imaging project.</span><span class="cgo">Ask →</span></button>
        </div>
      </section>

    </div>

    <div class="composer">
      <div class="chatcol">
        <form class="field" onsubmit="return false;">
          <input id="ask" type="text" placeholder="Ask a question about Rishikesh…" autocomplete="off" />
          <button class="send" type="submit">Send <span class="arr">→</span></button>
        </form>
        <div class="hint">
          <span class="mono">Grounded in résumé &amp; project notes</span>
          <span class="mono">Press ⏎ to send</span>
        </div>
      </div>
    </div>
  </main>
</Base>

<style is:global>
  .chatmain {
    min-height: calc(100vh - 64px);
    min-height: calc(100svh - 64px);
    display: flex; flex-direction: column;
  }
  .chatcol { max-width: 760px; margin: 0 auto; padding: 0 56px; width: 100%; }

  /* intro */
  .intro { padding: 64px 0 28px; }
  .intro .eyebrow { display: block; margin-bottom: 22px; }
  .intro h1 {
    font-family: var(--serif); font-weight: 500; font-size: clamp(30px, 4.4vw, 44px);
    line-height: 1.08; letter-spacing: -0.03em; margin: 0; max-width: 20ch;
  }
  .intro h1 em { font-style: normal; font-weight: 600; color: var(--ink); }
  .intro .caret {
    display: inline-block; width: 3px; height: 0.86em;
    background: var(--ink); margin-left: 6px; transform: translateY(2px);
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink { 0%,50% { opacity: 1; } 50.01%,100% { opacity: 0; } }
  .eyebrow .status {
    display: inline-flex; align-items: center; gap: 7px; margin-left: 10px;
    padding-left: 12px; border-left: 1px solid var(--line);
  }
  .eyebrow .status .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink); position: relative; }
  .eyebrow .status .dot::after {
    content: ""; position: absolute; inset: 0; border-radius: 50%;
    background: var(--ink); animation: ping 2.4s ease-out infinite;
  }
  @keyframes ping { 0% { transform: scale(1); opacity: .45; } 80%,100% { transform: scale(3.4); opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .intro .caret, .eyebrow .status .dot::after { animation: none; } }

  /* thread */
  .thread { padding-bottom: 24px; }
  .exchange { padding: 30px 0; border-top: 1px solid var(--line); }
  .exchange:first-child { border-top: 0; }
  .q { display: grid; grid-template-columns: 64px 1fr; gap: 18px; align-items: start; }
  .q .qlabel { color: var(--accent); padding-top: 5px; }
  .q .qtext {
    font-family: var(--serif); font-weight: 400; font-size: 22px; line-height: 1.35;
    letter-spacing: -0.01em; margin: 0;
  }
  .a { display: grid; grid-template-columns: 64px 1fr; gap: 18px; align-items: start; margin-top: 20px; }
  .a .alabel { color: var(--ink-2); padding-top: 4px; }
  .a .atext { margin: 0; color: var(--ink); }
  .a .atext p { margin: 0 0 14px; }
  .a .atext p:last-child { margin-bottom: 0; }
  .a .atext .hl { color: var(--accent); font-weight: 500; }
  .a .atext strong { font-weight: 500; }
  .a .atext .cite {
    display: inline-block; margin-top: 4px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-2); border: 1px solid var(--line); border-radius: 2px; padding: 3px 8px; text-decoration: none;
  }
  .a .atext .cite:hover { color: var(--accent); border-color: var(--accent); }

  /* suggestions */
  .suggest { padding: 8px 0 34px; }
  .suggest .sl { display: block; margin-bottom: 14px; }
  .chips { display: flex; flex-direction: column; gap: 0; }
  .chip {
    display: flex; align-items: center; justify-content: space-between; gap: 14px;
    text-align: left; width: 100%; cursor: pointer;
    background: none; border: 0; border-top: 1px solid var(--line);
    padding: 15px 2px; font: inherit; color: var(--ink);
    transition: padding-left .25s ease, color .25s ease;
  }
  .chip:last-child { border-bottom: 1px solid var(--line); }
  .chip .ct { font-family: var(--serif); font-size: 18px; }
  .chip .cgo { font-family: var(--mono); font-size: 13px; color: var(--ink-2); white-space: nowrap; transition: transform .25s ease, color .25s ease; }
  .chip:hover { padding-left: 12px; color: var(--accent); }
  .chip:hover .cgo { color: var(--accent); transform: translateX(3px); }

  /* composer */
  .composer {
    position: sticky; bottom: 0; margin-top: auto;
    background: linear-gradient(to top, var(--paper) 72%, transparent);
    padding-bottom: 26px; padding-top: 14px;
  }
  .field {
    display: flex; align-items: center; gap: 14px;
    border: 1px solid var(--ink); border-radius: 4px; background: var(--paper);
    padding: 4px 4px 4px 18px;
    transition: border-color .2s ease, box-shadow .2s ease;
  }
  .field:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent); }
  .field input {
    flex: 1; border: 0; background: none; outline: none;
    font-family: var(--sans); font-size: 16.5px; color: var(--ink); padding: 14px 0;
  }
  .field input::placeholder { color: var(--ink-2); opacity: .8; }
  .send {
    flex: none; display: inline-flex; align-items: center; gap: 8px;
    border: 0; cursor: pointer; background: var(--accent); color: var(--paper);
    font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 12px 16px; border-radius: 3px; transition: background .2s ease, transform .2s ease;
  }
  .send:hover { background: color-mix(in srgb, var(--accent) 82%, var(--paper)); }
  .send .arr { font-family: var(--sans); font-size: 15px; transition: transform .25s ease; }
  .send:hover .arr { transform: translateX(3px); }
  .composer .hint { display: flex; justify-content: space-between; gap: 12px; margin-top: 10px; }

  /* typing caret for streamed answers */
  .typing-caret {
    display: inline-block; width: 2px; height: 1em; background: var(--ink);
    margin-left: 2px; transform: translateY(2px); animation: blink 1.1s steps(1) infinite;
  }

  @media (max-width: 720px) {
    .chatcol { padding: 0 22px; }
    .intro { padding: 40px 0 20px; }
    .q, .a { grid-template-columns: 1fr; gap: 8px; }
    .q .qlabel, .a .alabel { padding-top: 0; }
    .q .qtext { font-size: 20px; }
    .chip .ct { font-size: 16.5px; }
  }
</style>